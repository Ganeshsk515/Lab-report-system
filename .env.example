SECRET_KEY=replace-with-a-long-random-value
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-admin-password

# Supabase configuration
# Option A: full URL (leave empty if using Option B)
SUPABASE_DB_URL=
# Option B: project ref + raw DB password (app encodes special characters safely)
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

POSTGRES_DB=diagnostics
POSTGRES_USER=diagnostics_user
POSTGRES_PASSWORD=diagnostics_password

# Email settings (required for verification and password reset links)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
EMAIL_VERIFY_TOKEN_MAX_AGE=86400
PASSWORD_RESET_TOKEN_MAX_AGE=3600
